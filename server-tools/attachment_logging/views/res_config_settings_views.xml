<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_form_view" model="ir.ui.view">
        <field
            name="name"
        >res.config.settings.form.view.inherited.attachment_logging</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="mail.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@id='emails']" position="inside">
                <setting
                    id="use_attachment_log"
                    string="Attachment Logging"
                    help="Log a note in record chatter when an attachment is added or removed."
                >
                    <field name="use_attachment_log" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
