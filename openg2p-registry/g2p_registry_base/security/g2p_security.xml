<odoo noupdate="0">
    <record model="ir.module.category" id="openg2p_module">
        <field name="name">OpenG2P Module Access</field>
        <field name="description">User access level for the OpenG2P module</field>
        <field name="sequence">3</field>
    </record>

<!-- OpenG2P Admin Group -->
    <record id="group_g2p_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="g2p_registry_base.openg2p_module" />
        <field name="implied_ids" eval="[Command.link(ref('base.group_partner_manager'))]" />
        <field
            name="users"
            eval="[Command.link(ref('base.user_root')), Command.link(ref('base.user_admin'))]"
        />
    </record>


<!-- Access to Create Registrant -->
    <record id="group_g2p_registrar" model="res.groups">
        <field name="name">Registrar</field>
        <field name="category_id" ref="g2p_registry_base.openg2p_module" />
        <field
            name="implied_ids"
            eval="
            [
                Command.link(ref('base.group_partner_manager')),
            ]"
        />

    </record>

    <record id="group_g2p_restrict_access_to_self" model="res.groups">
        <field name="name"> Restrict Access To Self </field>
        <field name="category_id" ref="g2p_registry_base.openg2p_module" />
    </record>

    <record id="res_users_hide_all_except_himself" model="ir.rule">
        <field name="name">Hide All Res Users Except Current User</field>
        <field name="model_id" ref="base.model_res_users" />
        <field name="global" eval="False" />
        <field name="domain_force">[('id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('g2p_registry_base.group_g2p_restrict_access_to_self'))]" />
    </record>

    <record id="res_partner_hide_all_except_himself" model="ir.rule">
        <field name="name">Hide All Partners Except Current User</field>
        <field name="model_id" ref="base.model_res_partner" />
        <field name="global" eval="False" />
        <field name="domain_force">[('id', '=', user.partner_id.id)]</field>
        <field name="groups" eval="[(4, ref('g2p_registry_base.group_g2p_restrict_access_to_self'))]" />
    </record>
</odoo>
