<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_odk_import_form" model="ir.ui.view">
        <field name="name">view_odk_import_form</field>
        <field name="model">odk.import</field>
        <field name="inherit_id" ref="g2p_odk_importer.view_odk_import_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='json_formatter']/.." position="after">
                <group string="Document Settings">
                    <field name="storage_backend_id" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
