<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Change Log Tree View -->
    <record id="view_change_log_tree" model="ir.ui.view">
        <field name="name">g2p.change.log.tree</field>
        <field name="model">g2p.change.log</field>
        <field name="arch" type="xml">
            <tree
                decoration-info="change_type == 'create'"
                decoration-warning="change_type == 'modify'"
                decoration-danger="change_type == 'delete'"
            >
                <field name="change_date" />
                <field name="change_type" />
                <field name="registrant_name" />
                <field name="change_summary" />
                <field name="changed_by" />
                <field name="change_request_name" />
                <field name="is_group" />
            </tree>
        </field>
    </record>

    <!-- Change Log Form View -->
    <record id="view_change_log_form" model="ir.ui.view">
        <field name="name">g2p.change.log.form</field>
        <field name="model">g2p.change.log</field>
        <field name="arch" type="xml">
            <form string="Change Log Entry">
                <header>
                    <field
                        name="change_type"
                        widget="badge"
                        decoration-info="change_type == 'create'"
                        decoration-warning="change_type == 'modify'"
                        decoration-danger="change_type == 'delete'"
                    />
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button
                            name="action_view_change_request"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-file-text-o"
                        >
                            <field name="change_request_id" widget="statinfo" string="Change Request" />
                        </button>
                        <button
                            name="action_view_registrant"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-user"
                        >
                            <field name="registrant_id" widget="statinfo" string="Registrant" />
                        </button>
                    </div>

                    <div class="oe_title">
                        <h1>
                            <field name="change_summary" readonly="1" />
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="change_date" readonly="1" />
                            <field name="changed_by" readonly="1" />
                            <field name="change_type" readonly="1" />
                        </group>
                        <group>
                            <field
                                name="registrant_id"
                                readonly="1"
                                context="{'form_view_ref': is_group and 'g2p_registry_group.view_groups_form' or 'g2p_registry_individual.view_individuals_form'}"
                            />
                            <field name="change_request_id" readonly="1" />
                            <field name="is_group" readonly="1" />
                        </group>
                    </group>

                    <notebook>
                    <page string="Change Details" name="change_details">
                        <div style="display: flex; width: 100%; gap: 10px;">
                            <div style="flex: 1; width: 50%;">
                                <h4
                                        style="margin: 0 0 10px 0; padding: 5px; border-radius: 4px;"
                                    >Old Values</h4>
                                <field
                                        name="old_values"
                                        widget="change_log_json_widget"
                                        readonly="1"
                                        nolabel="1"
                                        style="font-family: monospace;
                                        white-space: pre-wrap;
                                        width: 100%;
                                        display: block;"
                                    />
                            </div>
                            <div style="flex: 1; width: 50%;">
                                <h4
                                        style="margin: 0 0 10px 0; padding: 5px; border-radius: 4px;"
                                    >New Values</h4>
                                <field
                                        name="new_values"
                                        widget="change_log_json_widget"
                                        readonly="1"
                                        nolabel="1"
                                        style="font-family: monospace;
                                        white-space: pre-wrap;
                                        width: 100%;
                                        display: block;"
                                    />
                            </div>
                        </div>
                    </page>

                    <page string="Raw JSON" name="raw_json">
                        <div style="display: flex; width: 100%; gap: 10px;">
                            <div style="flex: 1; width: 50%;">
                                <h4
                                        style="margin: 0 0 10px 0; padding: 5px; border-radius: 4px;"
                                    >Old Values (Raw JSON)</h4>
                                <field
                                        name="old_values_formatted"
                                        widget="text"
                                        readonly="1"
                                        nolabel="1"
                                        style="font-family: monospace;
                                        white-space: pre-wrap;
                                        word-wrap: break-word;
                                        padding: 10px;
                                        border: 1px solid #dee2e6;
                                        border-radius: 4px;
                                        width: 100%;
                                        display: block;
                                        overflow: visible;"
                                    />
                            </div>
                            <div style="flex: 1; width: 50%;">
                                <h4
                                        style="margin: 0 0 10px 0; padding: 5px; border-radius: 4px;"
                                    >New Values (Raw JSON)</h4>
                                <field
                                        name="new_values_formatted"
                                        widget="text"
                                        readonly="1"
                                        nolabel="1"
                                        style="font-family: monospace;
                                        white-space: pre-wrap;
                                        word-wrap: break-word;
                                        padding: 10px;
                                        border: 1px solid #dee2e6;
                                        border-radius: 4px;
                                        width: 100%;
                                        display: block;
                                        overflow: visible;"
                                    />
                            </div>
                        </div>
                    </page>
                </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers" />
                    <field name="activity_ids" widget="mail_activity" />
                    <field name="message_ids" widget="mail_thread" />
                </div>
            </form>
        </field>
    </record>

    <!-- Change Log Search View -->
    <record id="view_change_log_search" model="ir.ui.view">
        <field name="name">g2p.change.log.search</field>
        <field name="model">g2p.change.log</field>
        <field name="arch" type="xml">
            <search string="Change Log">
                <field name="change_summary" string="Summary" />
                <field name="registrant_name" string="Registrant" />
                <field name="change_request_name" string="Change Request" />
                <field name="changed_by" string="Changed By" />

                <filter string="Create" name="filter_create" domain="[('change_type', '=', 'create')]" />
                <filter string="Modify" name="filter_modify" domain="[('change_type', '=', 'modify')]" />
                <filter string="Delete" name="filter_delete" domain="[('change_type', '=', 'delete')]" />

                <filter string="Groups" name="filter_groups" domain="[('is_group', '=', True)]" />
                <filter string="Individuals" name="filter_individuals" domain="[('is_group', '=', False)]" />

                <separator />
                <filter
                    string="Today"
                    name="filter_today"
                    domain="[('change_date', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"
                />
                <filter
                    string="This Week"
                    name="filter_this_week"
                    domain="[('change_date', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d'))]"
                />
                <filter
                    string="This Month"
                    name="filter_this_month"
                    domain="[('change_date', '>=', datetime.datetime.combine(context_today().replace(day=1), datetime.time(0,0,0)))]"
                />

                <group expand="0" string="Group By">
                    <filter
                        string="Change Type"
                        name="group_change_type"
                        context="{'group_by': 'change_type'}"
                    />
                    <filter
                        string="Changed By"
                        name="group_changed_by"
                        context="{'group_by': 'changed_by'}"
                    />
                    <filter
                        string="Registrant"
                        name="group_partner"
                        context="{'group_by': 'registrant_id'}"
                    />
                    <filter
                        string="Change Date"
                        name="group_change_date"
                        context="{'group_by': 'change_date:day'}"
                    />
                </group>
            </search>
        </field>
    </record>

    <!-- Change Log Action -->
    <record id="action_change_log" model="ir.actions.act_window">
        <field name="name">Change Log</field>
        <field name="res_model">g2p.change.log</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_change_log_search" />
        <field name="context">{'create': False, 'edit': False, 'delete': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No change log entries found!
            </p>
            <p>
                Change log entries are automatically created when change requests are approved and implemented.
                These are read-only audit records that cannot be modified or deleted.
            </p>
        </field>
    </record>

    <!-- Change Log Menu Item -->
    <menuitem
        id="menu_change_log"
        name="Change Log"
        parent="menu_change_management_root"
        action="action_change_log"
        sequence="30"
    />

    <!-- Configuration Menu -->
    <menuitem
        id="menu_change_management_config"
        name="Configuration"
        parent="menu_change_management_root"
        sequence="40"
    />


</odoo>
