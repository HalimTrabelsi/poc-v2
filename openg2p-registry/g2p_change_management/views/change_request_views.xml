<odoo>

<!-- Individual Change Requests Tree View -->
<record id="view_change_request_individual_tree" model="ir.ui.view">
    <field name="name">g2p.change.request.individual.tree</field>
    <field name="model">g2p.change.request</field>
    <field name="arch" type="xml">
        <tree
                multi_edit="1"
                create="true"
                delete="true"
                decoration-info="state == 'draft'"
                decoration-warning="state == 'submitted'"
                decoration-success="state == 'approved'"
                decoration-danger="state == 'rejected'"
            >
            <field name="name" />
            <field name="type" />
            <field name="registrant_name" string="Individual" />
            <field name="requester_id" />
            <field name="state" />
            <field name="change_reason" />
            <field name="change_source" />
            <field name="create_date" />
        </tree>
    </field>
</record>

<!-- Group Change Requests Tree View -->
<record id="view_change_request_group_tree" model="ir.ui.view">
    <field name="name">g2p.change.request.group.tree</field>
    <field name="model">g2p.change.request</field>
    <field name="arch" type="xml">
        <tree
                multi_edit="1"
                create="true"
                delete="true"
                decoration-info="state == 'draft'"
                decoration-warning="state == 'submitted'"
                decoration-success="state == 'approved'"
                decoration-danger="state == 'rejected'"
            >
            <field name="name" />
            <field name="type" />
            <field name="group_kind_id" string="Group Kind" />
            <field name="registrant_name" string="Group" />
            <field name="requester_id" />
            <field name="state" />
            <field name="change_reason" />
            <field name="change_source" />
            <field name="create_date" />
        </tree>
    </field>
</record>

<record id="view_change_request_form" model="ir.ui.view">
    <field name="name">g2p.change.request.form</field>
    <field name="model">g2p.change.request</field>
    <field name="arch" type="xml">
        <form>
            <header>
                <button
                        name="action_submit"
                        string="Submit"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                    />
                <button
                        name="action_approve"
                        string="Approve"
                        type="object"
                        class="btn-success"
                        invisible="state != 'submitted'"
                    />
                <button
                        name="action_reject"
                        string="Reject"
                        type="object"
                        class="btn-danger"
                        invisible="state != 'submitted'"
                    />
                <button
                        name="action_edit_draft_record"
                        string="Go to Draft Registrant "
                        type="object"
                        class="btn-info"
                        invisible="state == 'approved' or not draft_record_id"
                    />
                <field
                        name="state"
                        widget="statusbar"
                        statusbar_visible="draft,submitted,approved,rejected"
                    />
            </header>
            <sheet>
                <group>
                    <group string="Change Request Information">
                        <field name="name" />
                        <field name="type" readonly="1" />
                        <field name="state" readonly="1" />
                        <field name="is_group" readonly="draft_record_id" />
                    </group>
                    <group string="Request Details">
                        <field name="requester_id" readonly="draft_record_id" />
                        <field name="change_reason" readonly="state and state != 'draft'" />
                        <field
                                name="change_source"
                                placeholder="Select change source"
                                readonly="state and state != 'draft'"
                            />
                    </group>
                </group>

                <group>
                    <group string="Registrant Information">
                        <field
                                name="registrant_id"
                                string="Registrant"
                                readonly="draft_record_id"
                                context="{'form_view_ref': is_group and 'g2p_registry_group.view_groups_form' or 'g2p_registry_individual.view_individuals_form'}"
                            />
                        <field name="group_kind_id" invisible="not is_group" readonly="draft_record_id" />
                    </group>
                    <group string="Approval Information" invisible="state == 'draft'">
                        <field
                                name="approver_id"
                                readonly="1"
                                invisible="state not in ['approved', 'rejected']"
                            />
                        <field name="rejection_reason" readonly="1" invisible="state != 'rejected'" />
                    </group>
                </group>

                <!-- Draft Record Information -->
                <field name="draft_record_id" invisible="1" />
                <div invisible="draft_record_id" class="alert alert-info" role="alert">
                    <strong>No Draft Record Available</strong><br />
                    A draft record will be created automatically when you save this change request.
                </div>
                    <notebook>
                    <page name="documents" string="Documents">
                                <field
                                name="supporting_documents_ids"
                                nolabel="1"
                                colspan="2"
                                context="{'registry_documents': True, }"
                            >
                                    <tree default_order="id desc">
                                        <field name="slug" string="Name" readonly="1" />
                                        <field name="tags_ids" widget="many2many_tags" readonly="1" />
                                        <field name="url" readonly="1" column_invisible="1" />
                                        <field name="file_type" readonly="1" />
                                        <field name="mimetype" readonly="1" column_invisible="1" />
                                        <widget name="g2p_documents_action_preview" />
                                    </tree>
                                </field>
                            </page>
                </notebook>
            </sheet>
            <div class="oe_chatter">
                <field name="message_follower_ids" />
                <field name="activity_ids" />
                <field name="message_ids" />
            </div>
        </form>
    </field>
</record>

<!-- Individual Change Request Form View -->
<record id="view_change_request_individual_form" model="ir.ui.view">
    <field name="name">g2p.change.request.individual.form</field>
    <field name="model">g2p.change.request</field>
    <field name="inherit_id" ref="view_change_request_form" />
    <field name="arch" type="xml">
        <xpath expr="//field[@name='is_group']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='state']" position="attributes">
            <attribute name="readonly">1</attribute>
        </xpath>
    </field>
</record>

<!-- Group Change Request Form View -->
<record id="view_change_request_group_form" model="ir.ui.view">
    <field name="name">g2p.change.request.group.form</field>
    <field name="model">g2p.change.request</field>
    <field name="inherit_id" ref="view_change_request_form" />
    <field name="arch" type="xml">
        <xpath expr="//field[@name='is_group']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
        <xpath expr="//field[@name='state']" position="attributes">
            <attribute name="readonly">1</attribute>
        </xpath>
    </field>
</record>

<record id="view_change_request_search" model="ir.ui.view">
    <field name="name">g2p.change.request.search</field>
    <field name="model">g2p.change.request</field>
    <field name="arch" type="xml">
        <search>
            <field name="name" />
            <field name="registrant_name" />
            <field name="requester_id" />
            <field name="change_reason" />
            <field name="change_source" />
            <field name="type" />
            <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]" />
            <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]" />
            <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]" />
            <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]" />
            <filter string="My Requests" name="my_requests" domain="[('requester_id', '=', uid)]" />
            <filter
                    string="Individual"
                    name="individual"
                    domain="[('is_group', '=', False), ('state', 'in', ['draft', 'submitted'])]"
                />
            <filter
                    string="Group"
                    name="group"
                    domain="[('is_group', '=', True), ('state', 'in', ['draft', 'submitted'])]"
                />
            <group expand="0" string="Group By">
                <filter string="State" name="group_state" context="{'group_by': 'state'}" />
                <filter string="Type" name="group_type" context="{'group_by': 'type'}" />
                <filter string="Requester" name="group_requester" context="{'group_by': 'requester_id'}" />
                <filter
                        string="Creation Date"
                        name="group_create_date"
                        context="{'group_by': 'create_date:day'}"
                    />
            </group>
        </search>
    </field>
</record>

