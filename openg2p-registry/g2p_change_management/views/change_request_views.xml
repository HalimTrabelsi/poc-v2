    <field name="model_id" ref="model_g2p_change_request" />
    <field name="state">code</field>
    <field name="binding_model_id" ref="model_g2p_change_request" />
    <field name="binding_view_types">list</field>
    <field name="groups_id" eval="[(4, ref('g2p_change_management.group_change_management_approver'))]" />
