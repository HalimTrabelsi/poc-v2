<!-- Individual Change Requests Action -->
<record id="action_change_request_individual" model="ir.actions.act_window">
    <field name="name">Individuals</field>
    <field name="res_model">g2p.change.request</field>
    <field name="view_mode">tree,form</field>
    <field name="view_id" ref="view_change_request_individual_tree" />
    <field name="domain">[('is_group', '=', False)]</field>
    <field name="context">{'default_is_group': False, 'search_default_individual': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first individual change request!
        </p>
        <p>
            Individual change requests are for changes to individual registrants.
        </p>
    </field>
    <field
            name="views"
            eval="[(ref('view_change_request_individual_tree'), 'tree'), (ref('view_change_request_individual_form'), 'form')]"
        />
</record>

<!-- Group Change Requests Action -->
<record id="action_change_request_group" model="ir.actions.act_window">
    <field name="name">Groups</field>
    <field name="res_model">g2p.change.request</field>
    <field name="view_mode">tree,form</field>
    <field name="view_id" ref="view_change_request_group_tree" />
    <field name="domain">[('is_group', '=', True)]</field>
    <field name="context">{'default_is_group': True, 'search_default_group': 1}</field>
    <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
            Create your first group change request!
        </p>
        <p>
            Group change requests are for changes to group registrants.
        </p>
    </field>
    <field
            name="views"
            eval="[(ref('view_change_request_group_tree'), 'tree'), (ref('view_change_request_group_form'), 'form')]"
        />
</record>

<menuitem id="menu_change_management_root" name="Change Management" sequence="10" />

<menuitem
        id="menu_change_request_individual"
        name="Individuals"
        parent="menu_change_management_root"
        action="action_change_request_individual"
        sequence="10"
    />

<menuitem
        id="menu_change_request_group"
        name="Groups"
        parent="menu_change_management_root"
        action="action_change_request_group"
        sequence="20"
    />

</odoo>
