<odoo>

<record id="module_category_change_management" model="ir.module.category">
    <field name="name">Change Management</field>
    <field name="description">User access level for the Change Management module</field>
    <field name="sequence">3</field>
</record>
<record id="group_change_management_user" model="res.groups">
    <field name="name">User</field>
    <field name="category_id" ref="module_category_change_management" />
</record>

<record id="group_change_management_approver" model="res.groups">
    <field name="name">Approver</field>
    <field name="implied_ids" eval="[(4, ref('group_change_management_user'))]" />
    <field name="category_id" ref="module_category_change_management" />
</record>

<record id="group_change_management_admin" model="res.groups">
    <field name="name">Admin</field>
    <field
            name="implied_ids"
            eval="[
        (4, ref('group_change_management_approver')),
        (4, ref('g2p_documents.group_g2p_document_admin')),
    ]"
        />
    <field name="category_id" ref="module_category_change_management" />
</record>


<record id="rule_g2p_change_management_draft_record_follower_restriction" model="ir.rule">
    <field name="name">Change Management Record Follower</field>
    <field name="model_id" ref="model_g2p_draft_record" />
    <field name="domain_force">
        ['|', ('message_partner_ids', 'in', [user.partner_id.id]), ('message_partner_ids', '=', False)]
    </field>
    <field
            name="groups"
            eval="[(6, 0, [
        ref('g2p_change_management.group_change_management_user'),
        ref('g2p_change_management.group_change_management_approver')
    ])]"
        />
</record>

<record id="g2p_change_management_rule_draft_record_admin_view_all" model="ir.rule">
    <field name="name">Admin Can View All Draft Imported Records</field>
    <field name="model_id" ref="model_g2p_draft_record" />
    <field name="groups" eval="[(6, 0, [ref('g2p_change_management.group_change_management_admin')])]" />
    <field name="domain_force">[(1, '=', 1)]</field>
</record>

</odoo>
