<odoo>
    <record id="view_res_partner_form_inherit_registration" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.registration</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group
                    string="ODK User Configuration"
                    invisible="context.get('default_supplier_rank') &lt; 1"
                >
                    <group col="6" colspan="6">
                        <group colspan="3">
                            <field name="odk_config_id" options="{'no_create': True}" />
                            <field name="odk_app_user" options="{'no_create': True}" />
                        </group>
                        <group colspan="3">
                            <button
                                class="oe_highlight"
                                name="fetch_odk_app_users"
                                string="Sync ODK Users"
                                type="object"
                                style="width: 100%; text-align: center;"
                                invisible="not odk_config_id"
                            />
                        </group>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
