<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- Stage Form View -->
    <record id="view_support_stage_form" model="ir.ui.view">
        <field name="name">support.stage.form</field>
        <field name="model">support.stage</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name" />
                            <field name="sequence" />
                            <field name="is_default" />
                            <field name="fold" />
                            <field name="done" />
                        </group>
                        <group>
                            <field name="team_ids" widget="many2many_tags" />
                            <field name="template_id" />
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Stage Tree View -->
    <record id="view_support_stage_tree" model="ir.ui.view">
        <field name="name">support.stage.tree</field>
        <field name="model">support.stage</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="fold" />
                <field name="done" />
            </tree>
        </field>
    </record>

    <!-- Stage Action Window -->
    <record id="action_support_stage" model="ir.actions.act_window">
        <field name="name">Support Stages</field>
        <field name="res_model">support.stage</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first support stage!
            </p>
        </field>
    </record>
</odoo>
