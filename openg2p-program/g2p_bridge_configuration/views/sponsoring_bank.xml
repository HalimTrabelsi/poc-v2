<odoo>
    <record id="view_g2p_sponsoring_bank_account_tree" model="ir.ui.view">
        <field name="name">g2p.sponsoring.bank.account.tree</field>
        <field name="model">g2p.sponsoring.bank.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="account_name" />
                <field name="bank_code" />
                <field name="account_number" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_sponsoring_bank_account_form" model="ir.ui.view">
        <field name="name">g2p.sponsoring.bank.account.form</field>
        <field name="model">g2p.sponsoring.bank.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="account_name" required="1" />
                        <field name="bank_code" required="1" />
                        <field name="bank_branch" required="1" />
                        <field name="account_number" required="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_g2p_sponsoring_bank_account" model="ir.actions.act_window">
        <field name="name">Sponsoring Bank Accounts</field>
        <field name="res_model">g2p.sponsoring.bank.account</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_g2p_sponsoring_bank_account"
        name="Sponsoring Bank Accounts"
        parent="g2p_programs.g2p_program_configuration_menu_root"
        groups="g2p_registry_base.group_g2p_admin,g2p_programs.g2p_program_manager"
        action="action_g2p_sponsoring_bank_account"
        sequence="20"
    />

</odoo>
